---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import BackToTop from '../components/BackToTop.astro';
---

<Layout title="隐私政策 — 唯蟹 Team">
  <Navbar />
  <main class="min-h-screen bg-[color:var(--color-bg)] py-20 px-6">
    <div class="max-w-3xl mx-auto">
      <h1 class="font-[family-name:var(--font-display)] text-3xl md:text-4xl font-bold text-[color:var(--color-midnight)] mb-8">
        隐私政策
      </h1>
      
      <div class="prose prose-lg">
        <p class="text-[color:var(--color-muted)] mb-6">
          生效日期：2026年1月1日
        </p>

        <section class="mb-10">
          <h2 class="font-[family-name:var(--font-display)] text-xl font-semibold text-[color:var(--color-midnight)] mb-4">
            一、引言
          </h2>
          <p class="text-[color:var(--color-text)] leading-relaxed">
            欢迎访问唯蟹 Team（以下简称"我们"）。我们深知个人信息对您的重要性，并会尽全力保护您的个人信息安全可靠。本隐私政策适用于您通过本网站与我们进行的互动。
          </p>
        </section>

        <section class="mb-10">
          <h2 class="font-[family-name:var(--font-display)] text-xl font-semibold text-[color:var(--color-midnight)] mb-4">
            二、个人信息处理者信息
          </h2>
          <p class="text-[color:var(--color-text)] leading-relaxed">
            唯蟹 Team 是本网站个人信息的处理者。
          </p>
          <p class="text-[color:var(--color-text)] leading-relaxed mt-2">
            联系方式：hs@horatio.cn
          </p>
        </section>

        <section class="mb-10">
          <h2 class="font-[family-name:var(--font-display)] text-xl font-semibold text-[color:var(--color-midnight)] mb-4">
            三、我们收集的个人信息
          </h2>
          <p class="text-[color:var(--color-text)] leading-relaxed mb-4">
            在您使用本网站时，我们可能会收集以下信息：
          </p>
          <ul class="list-disc list-inside text-[color:var(--color-text)] leading-relaxed space-y-2 ml-4">
            <li><strong>日志信息</strong>：IP 地址、浏览器类型、操作系统、访问时间、页面浏览记录</li>
            <li><strong>设备信息</strong>：设备型号、设备标识符</li>
            <li><strong>Cookie 信息</strong>：通过 Cookie 和类似技术收集的信息</li>
            <li><strong>联系信息</strong>：您主动向我们提供的电子邮件地址等联系方式</li>
          </ul>
        </section>

        <section class="mb-10">
          <h2 class="font-[family-name:var(--font-display)] text-xl font-semibold text-[color:var(--color-midnight)] mb-4">
            四、我们如何使用个人信息
          </h2>
          <p class="text-[color:var(--color-text)] leading-relaxed mb-4">
            我们收集的个人信息将用于以下目的：
          </p>
          <ul class="list-disc list-inside text-[color:var(--color-text)] leading-relaxed space-y-2 ml-4">
            <li>提供、维护和改进我们的服务</li>
            <li>保障网站安全，防范欺诈和滥用行为</li>
            <li>遵守法律法规要求</li>
            <li>响应您的请求和询问</li>
          </ul>
        </section>

        <section class="mb-10">
          <h2 class="font-[family-name:var(--font-display)] text-xl font-semibold text-[color:var(--color-midnight)] mb-4">
            五、个人信息的保存期限
          </h2>
          <p class="text-[color:var(--color-text)] leading-relaxed">
            我们仅在实现收集目的所需的期限内保留您的个人信息。日志信息通常保存不超过 6 个月，除非法律法规另有要求。
          </p>
        </section>

        <section class="mb-10">
          <h2 class="font-[family-name:var(--font-display)] text-xl font-semibold text-[color:var(--color-midnight)] mb-4">
            六、个人信息的共享与披露
          </h2>
          <p class="text-[color:var(--color-text)] leading-relaxed mb-4">
            未经您的同意，我们不会向第三方共享您的个人信息，但以下情况除外：
          </p>
          <ul class="list-disc list-inside text-[color:var(--color-text)] leading-relaxed space-y-2 ml-4">
            <li>获得您的明确同意</li>
            <li>根据适用的法律法规、法律程序或政府机关的强制性要求</li>
            <li>在紧急情况下，为保护您或其他人的合法权益</li>
          </ul>
        </section>

        <section class="mb-10">
          <h2 class="font-[family-name:var(--font-display)] text-xl font-semibold text-[color:var(--color-midnight)] mb-4">
            七、Cookie 使用
          </h2>
          <p class="text-[color:var(--color-text)] leading-relaxed">
            我们使用 Cookie 和类似技术来保障网站正常运行、分析流量和改善用户体验。您可以通过浏览器设置管理 Cookie。
          </p>
        </section>

        <section class="mb-10">
          <h2 class="font-[family-name:var(--font-display)] text-xl font-semibold text-[color:var(--color-midnight)] mb-4">
            八、您的权利
          </h2>
          <p class="text-[color:var(--color-text)] leading-relaxed mb-4">
            根据《中华人民共和国个人信息保护法》，您享有以下权利：
          </p>
          <ul class="list-disc list-inside text-[color:var(--color-text)] leading-relaxed space-y-2 ml-4">
            <li><strong>知情权</strong>：了解我们如何处理您的个人信息</li>
            <li><strong>决定权</strong>：限制或拒绝他人处理您的个人信息</li>
            <li><strong>查阅复制权</strong>：查阅、复制您的个人信息</li>
            <li><strong>更正补充权</strong>：更正、补充不准确或不完整的个人信息</li>
            <li><strong>删除权</strong>：在特定条件下删除您的个人信息</li>
            <li><strong>撤回同意权</strong>：撤回您此前作出的同意</li>
          </ul>
          <p class="text-[color:var(--color-text)] leading-relaxed mt-4">
            如需行使上述权利，请通过本政策提供的联系方式与我们联系。
          </p>
        </section>

        <section class="mb-10">
          <h2 class="font-[family-name:var(--font-display)] text-xl font-semibold text-[color:var(--color-midnight)] mb-4">
            九、未成年人保护
          </h2>
          <p class="text-[color:var(--color-text)] leading-relaxed">
            我们非常重视对未成年人个人信息的保护。如果您是 14 周岁以下的未成年人，请在您的监护人的指导下使用我们的服务。
          </p>
        </section>

        <section class="mb-10">
          <h2 class="font-[family-name:var(--font-display)] text-xl font-semibold text-[color:var(--color-midnight)] mb-4">
            十、隐私政策的更新
          </h2>
          <p class="text-[color:var(--color-text)] leading-relaxed">
            我们可能会不时更新本隐私政策。更新后的隐私政策将在本页面上发布，并注明生效日期。建议您定期查看本页面。
          </p>
        </section>

        <section class="mb-10">
          <h2 class="font-[family-name:var(--font-display)] text-xl font-semibold text-[color:var(--color-midnight)] mb-4">
            十一、联系我们
          </h2>
          <p class="text-[color:var(--color-text)] leading-relaxed">
            如果您对本隐私政策有任何疑问、意见或建议，请通过以下方式与我们联系：
          </p>
          <p class="text-[color:var(--color-primary)] mt-4">
            <a href="mailto:hs@horatio.cn" class="hover:underline">hs@horatio.cn</a>
          </p>
        </section>
      </div>
    </div>
  </main>
  <Footer />
  <BackToTop />
</Layout>
