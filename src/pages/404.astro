---
import Layout from '../layouts/Layout.astro';
---

<Layout title="页面未找到 — 唯蟹 Team">
  <main class="min-h-screen bg-[color:var(--color-bg)] flex items-center justify-center px-6">
    <div class="text-center max-w-md">
      <img src="/favicon.png" alt="唯蟹 Team" class="w-20 h-20 mx-auto mb-8 rounded-[20px] shadow-md" width="80" height="80" />
      <div class="text-[6rem] leading-none font-[family-name:var(--font-display)] font-bold text-[color:var(--color-primary)] mb-4">404</div>
      <h1 class="font-[family-name:var(--font-display)] text-2xl font-semibold text-[color:var(--color-midnight)] mb-3">
        对不起，页面不存在
      </h1>
      <p class="text-[color:var(--color-muted)] text-base leading-relaxed mb-8">
        您访问的页面可能已被删除或链接错误。
      </p>
      <a href="https://www.wxies.cn" class="inline-flex items-center gap-2 px-7 py-3.5 rounded-full bg-[color:var(--color-primary)] text-white font-semibold text-sm shadow-[0_4px_14px_-4px_rgba(0,122,255,0.5)] hover:shadow-[0_6px_20px_-6px_rgba(0,122,255,0.6)] hover:-translate-y-0.5 active:translate-y-0 transition-all duration-200">
        返回主页
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
      </a>
    </div>
  </main>
</Layout>
