---
import '../styles/global.css';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@500;600;700&display=swap" />
    <title>页面未找到 — 唯蟹 Team</title>
    <link rel="shortcut icon" href="/images/favicons/favicon.png" />
  </head>
  <body class="min-h-screen bg-[color:var(--color-bg)] flex items-center justify-center px-6">
    <div class="text-center max-w-md">
      <img src="/images/favicons/favicon.png" alt="唯蟹 Team" class="w-20 h-20 mx-auto mb-8 rounded-2xl shadow-md" />
      <div class="text-[6rem] leading-none font-[family-name:var(--font-display)] font-bold text-[color:var(--color-primary)] mb-4">404</div>
      <h1 class="font-[family-name:var(--font-display)] text-2xl font-semibold text-[color:var(--color-midnight)] mb-3">
        对不起，页面不存在
      </h1>
      <p class="text-[color:var(--color-muted)] text-base leading-relaxed mb-8">
        您访问的页面可能已被删除或链接错误。
      </p>
      <a href="https://www.wxies.cn" class="inline-flex items-center gap-2 px-7 py-3.5 rounded-xl bg-[color:var(--color-primary)] text-white font-medium text-sm shadow-[0_10px_30px_-10px_rgba(57,86,222,0.6)] hover:shadow-[0_14px_40px_-12px_rgba(57,86,222,0.7)] hover:-translate-y-0.5 transition-all duration-300">
        返回主页
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
      </a>
    </div>
  </body>
</html>
